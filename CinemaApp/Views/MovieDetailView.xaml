<UserControl x:Class="CinemaApp.Views.MovieDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Back button -->
        <Button Grid.Row="0" Style="{StaticResource GhostButtonStyle}" Margin="20,12,0,0"
                HorizontalAlignment="Left" Content="← Назад"
                Command="{Binding GoBackCommand}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,12,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Poster -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <Border CornerRadius="12" ClipToBounds="True" Height="360">
                        <Border.Effect>
                            <DropShadowEffect Color="#E50914" BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
                        </Border.Effect>
                        <Image Source="{Binding Movie.PosterUrl}" Stretch="UniformToFill"/>
                    </Border>

                    <Button Style="{StaticResource AccentButtonStyle}" Margin="0,16,0,0"
                            Content="Выбрать сеанс" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- Details -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Movie.Title}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="26" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Movie.OriginalTitle}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" Margin="0,4,0,0"/>

                    <!-- Meta row -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="8,3">
                            <TextBlock Text="{Binding Movie.AgeRating}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="{Binding Movie.Year}" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center">
                            <Run Text="{Binding Movie.DurationMinutes}"/><Run Text=" мин"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Rating -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="★" Foreground="{StaticResource GoldBrush}" FontSize="22"/>
                        <TextBlock Text="{Binding Movie.ImdbRating, StringFormat=F1}"
                                   Foreground="{StaticResource GoldBrush}" FontSize="22" FontWeight="Bold" Margin="6,0,0,0"/>
                        <TextBlock Text="/ 10 · IMDb" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" Margin="6,0,0,0" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <!-- Genre -->
                    <TextBlock Text="{Binding Movie.Genre}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,8,0,0"/>

                    <!-- Director + Cast -->
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,14,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Режиссёр" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Movie.Director}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="В ролях" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Movie.Cast}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- Description -->
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,14,0,14"/>
                    <TextBlock Text="О фильме" Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Movie.Description}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>

                    <!-- Today's sessions -->
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,20,0,14"/>
                    <TextBlock Text="Сеансы сегодня" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding TodaySessions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,10,10" Padding="0"
                                        Command="{Binding DataContext.SelectSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                    Padding="16,10" Cursor="Hand">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding StartTime, StringFormat=HH:mm}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Hall.Name}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="11" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                                    <TextBlock Foreground="{StaticResource AccentBrush}"
                                                               FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                        <Run Text="{Binding BasePrice, StringFormat=N0}"/><Run Text=" ₽"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"
                               Visibility="{Binding HasNoTodaySessions, Converter={StaticResource BoolVis}}"
                               Text="Сегодня сеансов нет. Выберите другую дату."/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
