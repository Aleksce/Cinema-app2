<UserControl x:Class="CinemaApp.Views.MovieDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- Hover animation style for session cards -->
        <Style x:Key="SessionCardButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1.04" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1.04" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cast card hover -->
        <Style x:Key="CastCardStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform/></Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: back + trailer -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Button Style="{StaticResource GhostButtonStyle}" Content="← Назад"
                        HorizontalAlignment="Left" Command="{Binding GoBackCommand}"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0"
                            Command="{Binding GoToScheduleCommand}" Content="📅 Расписание →"/>
                    <Button Visibility="{Binding HasTrailer, Converter={StaticResource BoolVis}}"
                            Command="{Binding WatchTrailerCommand}"
                            Cursor="Hand" Padding="0" BorderThickness="0" Background="Transparent">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="8"
                                Padding="14,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶  " Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="Смотреть трейлер" Foreground="White"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ═══ HERO BACKDROP ═══════════════════════════════════ -->
                <Grid Height="240">
                    <!-- Backdrop image -->
                    <Image Source="{Binding Movie.BackdropUrl}" Stretch="UniformToFill"
                           VerticalAlignment="Center" Opacity="0.7"/>
                    <!-- Gradient overlay bottom -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00101018" Offset="0"/>
                                <GradientStop Color="#CC101018" Offset="0.7"/>
                                <GradientStop Color="#FF101018" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Poster + title overlay -->
                    <Grid Margin="24,0,24,0" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                                Height="200" VerticalAlignment="Bottom" Margin="0,0,0,-30">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" BlurRadius="20" Opacity="0.6" ShadowDepth="6"/>
                            </Border.Effect>
                            <Image Source="{Binding Movie.PosterUrl}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,8" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding Movie.Title}"
                                       Foreground="White" FontSize="24" FontWeight="Black"
                                       TextWrapping="Wrap">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="8" Opacity="0.8" ShadowDepth="2"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{Binding Movie.OriginalTitle}"
                                       Foreground="#AAC0C0D0" FontSize="13" Margin="0,3,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="7,2">
                                    <TextBlock Text="{Binding Movie.AgeRating}" Foreground="White"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="{Binding Movie.Year}" Foreground="#BBCDD0E0"
                                           FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="#BBCDD0E0" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Run Text="{Binding Movie.DurationMinutes}"/><Run Text=" мин"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="★" Foreground="{StaticResource GoldBrush}" FontSize="14"/>
                                    <TextBlock Text="{Binding Movie.ImdbRating, StringFormat=F1}"
                                               Foreground="{StaticResource GoldBrush}" FontSize="14"
                                               FontWeight="Bold" Margin="3,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ═══ BODY ══════════════════════════════════════════════ -->
                <StackPanel Margin="24,36,24,0">

                    <!-- Genre + "Выбрать сеанс" row -->
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="{Binding Movie.Genre}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Cursor="Hand"
                                Padding="0" BorderThickness="0" Background="Transparent"
                                Command="{Binding GoToScheduleCommand}">
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="18,9">
                                <TextBlock Text="Выбрать сеанс" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </Border>
                        </Button>
                    </Grid>

                    <!-- Director + Cast row -->
                    <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16,14" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Режиссёр"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Movie.Director}"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Rectangle Grid.Column="2" Width="1" Fill="{StaticResource BorderBrush}"
                                       Margin="16,0"/>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="В ролях" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding Movie.Cast}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ CAST WITH PHOTOS ════════════════════════════ -->
                    <TextBlock Text="В главных ролях" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"
                               Visibility="{Binding CastMembers.Count, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                        <ItemsControl ItemsSource="{Binding CastMembers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="90" Margin="0,0,12,0" Cursor="Hand">
                                        <StackPanel>
                                            <!-- Circular photo -->
                                            <Border Width="70" Height="70" CornerRadius="35"
                                                    ClipToBounds="True" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2A2A3A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <!-- Fallback avatar icon -->
                                                    <TextBlock Text="👤" FontSize="28"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPhoto}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Image Source="{Binding PhotoUrl}" Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       Margin="0,6,0,2" MaxWidth="86"/>
                                            <TextBlock Text="{Binding Character}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" TextWrapping="Wrap"
                                                       TextAlignment="Center" MaxWidth="86"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- ═══ DESCRIPTION ═════════════════════════════════ -->
                    <TextBlock Text="О фильме" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Movie.Description}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,20"/>

                    <!-- ═══ TODAY'S SESSIONS ════════════════════════════ -->
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Сеансы сегодня" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding TodaySessions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,10,0" Padding="0"
                                            Style="{StaticResource SessionCardButtonStyle}"
                                            Command="{Binding DataContext.SelectSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                Padding="18,12">
                                            <StackPanel MinWidth="90">
                                                <TextBlock Text="{Binding StartTime, StringFormat=HH:mm}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <Border Background="{StaticResource AccentBrush}" CornerRadius="4"
                                                        Padding="6,2" Margin="0,4,0,0" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Format}" Foreground="White"
                                                               FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock Text="{Binding Hall.Name}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="10" HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="110"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Foreground="{StaticResource GoldBrush}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" Margin="0,4,0,0">
                                                    <Run Text="{Binding BasePrice, StringFormat=N0}"/><Run Text=" ₽"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- No sessions message -->
                    <Border Visibility="{Binding HasNoTodaySessions, Converter={StaticResource BoolVis}}"
                            Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20,14"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ " Foreground="{StaticResource AccentBrush}" FontSize="14"/>
                            <StackPanel>
                                <TextBlock Text="На сегодня сеансов нет"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Перейдите в Расписание, чтобы выбрать другую дату"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Margin="0,4,0,24" Padding="0" BorderThickness="0" Background="Transparent"
                            HorizontalAlignment="Left" Cursor="Hand"
                            Command="{Binding GoToScheduleCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Все сеансы этого фильма →"
                                       Foreground="{StaticResource AccentBrush}" FontSize="13"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
