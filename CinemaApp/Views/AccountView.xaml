<UserControl x:Class="CinemaApp.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             xmlns:vm="clr-namespace:CinemaApp.ViewModels"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InitialsConverter         x:Key="Initials"/>
        <conv:StringToggleConverter     x:Key="StrToggle"/>

        <!-- Validation hint style — green for ✓, red for errors, grey for description -->
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="4,3,0,0"/>
            <Setter Property="Foreground" Value="#FF6060"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Text}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HintOkStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="4,3,0,0"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>

        <!-- Dark ComboBox drop-down item -->
        <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background"        Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"        Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding"           Value="10,8"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#33E50914"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,22,28,28">

            <!-- ══ LOGGED IN ═══════════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolVis}}">

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border Width="88" Height="88" CornerRadius="44" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E50914" Offset="0"/>
                                <GradientStop Color="#FF6B35" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding CurrentUser.FullName, Converter={StaticResource Initials}}"
                                   Foreground="White" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentUser.FullName}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="21" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,14,0,4"/>
                    <TextBlock Text="{Binding CurrentUser.Email}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loyalty card -->
                <Border CornerRadius="14" Padding="22,18" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="#4DE50914">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1C0A0F" Offset="0"/>
                            <GradientStop Color="#2A0A14" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#E50914" BlurRadius="20" Opacity="0.15" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="★" Foreground="{StaticResource GoldBrush}" FontSize="18"/>
                            <TextBlock Text=" СИНЕМА КЛУБ"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="28" FontWeight="Bold">
                            <Run Text="{Binding CurrentUser.LoyaltyPoints, StringFormat=N0}"/>
                            <Run Text=" баллов" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding LoyaltyProgress}" Minimum="0" Maximum="100"
                                     Height="6" Margin="0,12,0,5" Background="#2A2A38">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E50914" Offset="0"/>
                                    <GradientStop Color="#F5C842" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                            До следующего уровня:
                            <Run Text="{Binding LoyaltyProgress, StringFormat={}{0}%}"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Info card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="18,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📱 Телефон"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentUser.Phone, FallbackValue='Не указан'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="{StaticResource BorderBrush}" Margin="18,0"/>
                        <Grid Margin="18,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💳 Способ оплаты"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Visa **** 4242"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="{StaticResource BorderBrush}" Margin="18,0"/>
                        <Grid Margin="18,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⭐ Уровень"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentUser.LoyaltyLevel}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource GhostButtonStyle}" Content="Выйти из аккаунта"
                        HorizontalAlignment="Stretch" Margin="0,8,0,0"
                        Command="{Binding LogoutCommand}"/>
            </StackPanel>

            <!-- ══ LOGIN / REGISTER ════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsLoggedIn,
                Converter={StaticResource BoolVis}, ConverterParameter=invert}">

                <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="26" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           Text="{Binding ShowRegister,
                               Converter={StaticResource StrToggle},
                               ConverterParameter=Регистрация|Вход в аккаунт}"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,26"
                           Text="{Binding ShowRegister,
                               Converter={StaticResource StrToggle},
                               ConverterParameter=Создайте аккаунт для покупки билетов|Войдите чтобы увидеть свои билеты}"/>

                <!-- Error message -->
                <Border Background="#33E50914" CornerRadius="10" Padding="14,10" Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="#FF6B6B" FontSize="14"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B"
                                   FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ── LOGIN FORM ────────────────────────────────── -->
                <StackPanel Visibility="{Binding ShowRegister,
                    Converter={StaticResource BoolVis}, ConverterParameter=invert}">

                    <TextBlock Text="Email"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="100" Margin="0,0,0,14"/>

                    <TextBlock Text="Пароль"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="LoginPasswordBox"
                                 Style="{StaticResource DarkPasswordBoxStyle}"
                                 MaxLength="24"
                                 Margin="0,0,0,22"
                                 PasswordChanged="LoginPasswordBox_PasswordChanged"/>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Войти"
                            HorizontalAlignment="Stretch" Command="{Binding LoginCommand}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <TextBlock Text="Нет аккаунта? "
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ToggleRegisterCommand}">
                            <TextBlock Text="Создать"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- ── REGISTER FORM ─────────────────────────────── -->
                <StackPanel Visibility="{Binding ShowRegister, Converter={StaticResource BoolVis}}">

                    <!-- Name -->
                    <TextBlock Text="Имя и фамилия"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding RegisterName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="80" Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="100" Margin="0,0,0,4"/>

                    <!-- Email hint — green for ✓, red for error -->
                    <TextBlock Margin="4,3,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize"   Value="11"/>
                                <Setter Property="Foreground" Value="#FF6060"/>
                                <Setter Property="Text"       Value="{Binding EmailHint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmailHint}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EmailHint}" Value="✓">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Phone: country ComboBox + local digits -->
                    <TextBlock Text="Телефон (необязательно)"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Source={x:Static vm:AccountViewModel.Countries}}"
                                  SelectedItem="{Binding SelectedCountry}"
                                  Width="170" Margin="0,0,8,0"
                                  Background="{StaticResource CardBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  Padding="10,10"
                                  ItemContainerStyle="{StaticResource DarkComboItemStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBox Grid.Column="1"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="12">
                            <TextBox.Resources>
                                <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Цифры номера"
                                                                       Foreground="#555570"
                                                                       FontSize="13" Margin="12,10"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>

                    <!-- Phone hint -->
                    <TextBlock Margin="4,3,0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize"   Value="11"/>
                                <Setter Property="Foreground" Value="#FF6060"/>
                                <Setter Property="Text"       Value="{Binding PhoneHint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PhoneHint}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PhoneHint}" Value="✓">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Password -->
                    <TextBlock Text="Пароль"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="RegPasswordBox"
                                 Style="{StaticResource DarkPasswordBoxStyle}"
                                 MaxLength="24"
                                 Margin="0,0,0,4"
                                 PasswordChanged="RegPasswordBox_PasswordChanged"/>

                    <!-- Static password rules text -->
                    <TextBlock Margin="4,3,0,3" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Только латинские буквы и цифры · 8–24 символа · не начинается с цифры"/>

                    <!-- Dynamic password hint -->
                    <TextBlock Margin="4,2,0,18">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize"   Value="11"/>
                                <Setter Property="Foreground" Value="#FF6060"/>
                                <Setter Property="Text"       Value="{Binding PasswordHint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PasswordHint}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PasswordHint}" Value="✓">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Style="{StaticResource AccentButtonStyle}"
                            Content="Зарегистрироваться"
                            HorizontalAlignment="Stretch"
                            Command="{Binding RegisterCommand}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <TextBlock Text="Уже есть аккаунт? "
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ToggleRegisterCommand}">
                            <TextBlock Text="Войти"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Demo hint -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                        Padding="16,13" Margin="0,28,0,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🔑 Демо-доступ"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="Email: user@cinema.ru"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="Пароль: Cinema2024"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
