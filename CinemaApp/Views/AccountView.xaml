<UserControl x:Class="CinemaApp.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InitialsConverter x:Key="Initials"/>
        <conv:StringToggleConverter x:Key="StrToggle"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- LOGGED IN STATE -->
            <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolVis}}">

                <!-- Avatar + name -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Width="80" Height="80" CornerRadius="40" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="{Binding CurrentUser.FullName, Converter={StaticResource Initials}}"
                                   Foreground="White" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentUser.FullName}" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="{Binding CurrentUser.Email}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loyalty card -->
                <Border CornerRadius="12" Padding="20,16" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="#4DE50914">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1C0A0F" Offset="0"/>
                            <GradientStop Color="#2A0A14" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="★" Foreground="{StaticResource GoldBrush}" FontSize="16"/>
                            <TextBlock Text=" СИНЕМА КЛУБ" Foreground="{StaticResource GoldBrush}"
                                       FontSize="14" FontWeight="Bold" Margin="4,0,0,0"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="26" FontWeight="Bold">
                            <Run Text="{Binding CurrentUser.LoyaltyPoints, StringFormat=N0}"/>
                            <Run Text=" баллов" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding LoyaltyProgress}" Minimum="0" Maximum="100"
                                     Height="6" Margin="0,10,0,4" Background="#2A2A38">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E50914" Offset="0"/>
                                    <GradientStop Color="#F5C842" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                            До следующего уровня:
                            <Run Text="{Binding LoyaltyProgress, StringFormat={}{0}%}"
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Info rows -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="0,0,0,12">
                    <StackPanel>
                        <!-- Phone -->
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Телефон" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentUser.Phone, FallbackValue='Не указан'}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="{StaticResource BorderBrush}" Margin="16,0"/>
                        <!-- Payment -->
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Способ оплаты" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Visa **** 4242"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="{StaticResource BorderBrush}" Margin="16,0"/>
                        <!-- Level -->
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Уровень лояльности" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentUser.LoyaltyLevel}"
                                       Foreground="{StaticResource GoldBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Logout -->
                <Button Style="{StaticResource GhostButtonStyle}" Content="Выйти из аккаунта"
                        HorizontalAlignment="Stretch" Margin="0,8,0,0"
                        Command="{Binding LogoutCommand}"/>
            </StackPanel>

            <!-- LOGIN / REGISTER STATE -->
            <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolVis}, ConverterParameter=invert}">

                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           Text="{Binding ShowRegister, Converter={StaticResource StrToggle}, ConverterParameter=Регистрация|Вход в аккаунт}"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,28"
                           Text="{Binding ShowRegister, Converter={StaticResource StrToggle}, ConverterParameter=Создайте аккаунт для покупки билетов|Войдите чтобы увидеть свои билеты}"/>

                <!-- Error message -->
                <Border Background="#33E50914" CornerRadius="8" Padding="12,8" Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" FontSize="13"/>
                </Border>

                <!-- Login form -->
                <StackPanel Visibility="{Binding ShowRegister, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                    <TextBlock Text="Email" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}" Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                    <TextBlock Text="Пароль" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="LoginPasswordBox" Style="{StaticResource DarkPasswordBoxStyle}" Margin="0,0,0,20"
                                 PasswordChanged="LoginPasswordBox_PasswordChanged"/>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Войти"
                            HorizontalAlignment="Stretch" Command="{Binding LoginCommand}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <TextBlock Text="Нет аккаунта? " Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding ToggleRegisterCommand}">
                            <TextBlock Text="Создать" Foreground="{StaticResource AccentBrush}" FontSize="13"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Register form -->
                <StackPanel Visibility="{Binding ShowRegister, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="Имя и фамилия" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}" Text="{Binding RegisterName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Email" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}" Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Телефон" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}" Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Text="Пароль" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="RegPasswordBox" Style="{StaticResource DarkPasswordBoxStyle}" Margin="0,0,0,20"
                                 PasswordChanged="RegPasswordBox_PasswordChanged"/>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Зарегистрироваться"
                            HorizontalAlignment="Stretch" Command="{Binding RegisterCommand}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <TextBlock Text="Уже есть аккаунт? " Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding ToggleRegisterCommand}">
                            <TextBlock Text="Войти" Foreground="{StaticResource AccentBrush}" FontSize="13"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Demo hint -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="14,12" Margin="0,24,0,0">
                    <StackPanel>
                        <TextBlock Text="Демо-доступ" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Email: user@cinema.ru" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="Пароль: password123" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
