<UserControl x:Class="CinemaApp.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InitialsConverter x:Key="Initials"/>
        <conv:StringToggleConverter x:Key="StrToggle"/>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="4,3,0,6"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,22,28,28">

            <!-- ══ LOGGED IN ═══════════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolVis}}">

                <!-- Avatar + name -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border Width="88" Height="88" CornerRadius="44" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E50914" Offset="0"/>
                                <GradientStop Color="#FF6B35" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding CurrentUser.FullName, Converter={StaticResource Initials}}"
                                   Foreground="White" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentUser.FullName}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,14,0,4"/>
                    <TextBlock Text="{Binding CurrentUser.Email}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loyalty card -->
                <Border CornerRadius="14" Padding="22,18" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="#4DE50914">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1C0A0F" Offset="0"/>
                            <GradientStop Color="#2A0A14" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#E50914" BlurRadius="20" Opacity="0.15" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="★" Foreground="{StaticResource GoldBrush}" FontSize="18"/>
                            <TextBlock Text=" СИНЕМА КЛУБ" Foreground="{StaticResource GoldBrush}"
                                       FontSize="14" FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="28" FontWeight="Bold">
                            <Run Text="{Binding CurrentUser.LoyaltyPoints, StringFormat=N0}"/>
                            <Run Text=" баллов" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding LoyaltyProgress}" Minimum="0" Maximum="100"
                                     Height="6" Margin="0,12,0,5" Background="#2A2A38">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E50914" Offset="0"/>
                                    <GradientStop Color="#F5C842" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                            До следующего уровня:
                            <Run Text="{Binding LoyaltyProgress, StringFormat={}{0}%}"
                                 Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Info rows -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="14" Margin="0,0,0,14"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="18,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📱 Телефон" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentUser.Phone, FallbackValue='Не указан'}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="{StaticResource BorderBrush}" Margin="18,0"/>
                        <Grid Margin="18,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💳 Способ оплаты" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Visa **** 4242"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                        <Separator Background="{StaticResource BorderBrush}" Margin="18,0"/>
                        <Grid Margin="18,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⭐ Уровень" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentUser.LoyaltyLevel}"
                                       Foreground="{StaticResource GoldBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource GhostButtonStyle}" Content="Выйти из аккаунта"
                        HorizontalAlignment="Stretch" Margin="0,8,0,0"
                        Command="{Binding LogoutCommand}"/>
            </StackPanel>

            <!-- ══ LOGIN / REGISTER ════════════════════════════════ -->
            <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolVis}, ConverterParameter=invert}">

                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="26" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           Text="{Binding ShowRegister, Converter={StaticResource StrToggle}, ConverterParameter=Регистрация|Вход в аккаунт}"/>

                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,26"
                           Text="{Binding ShowRegister, Converter={StaticResource StrToggle}, ConverterParameter=Создайте аккаунт для покупки билетов|Войдите чтобы увидеть свои билеты}"/>

                <!-- Error message -->
                <Border Background="#33E50914" CornerRadius="10" Padding="14,10" Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="#FF6B6B" FontSize="14"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ── Login form ────────────────────────────────── -->
                <StackPanel Visibility="{Binding ShowRegister, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                    <TextBlock Text="Email" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                    <TextBlock Text="Пароль" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="LoginPasswordBox" Style="{StaticResource DarkPasswordBoxStyle}" Margin="0,0,0,22"
                                 PasswordChanged="LoginPasswordBox_PasswordChanged"/>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Войти"
                            HorizontalAlignment="Stretch" Command="{Binding LoginCommand}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <TextBlock Text="Нет аккаунта? " Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding ToggleRegisterCommand}">
                            <TextBlock Text="Создать" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- ── Register form ─────────────────────────────── -->
                <StackPanel Visibility="{Binding ShowRegister, Converter={StaticResource BoolVis}}">

                    <!-- Name -->
                    <TextBlock Text="Имя и фамилия" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding RegisterName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <!-- Email with hint -->
                    <TextBlock Text="Email" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                    <TextBlock Margin="4,3,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Text" Value="{Binding EmailHint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmailHint}" Value="✓">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Phone with hint -->
                    <TextBlock Text="Телефон" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                    <TextBlock Margin="4,3,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Text" Value="{Binding PhoneHint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PhoneHint}" Value="✓">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Password with hint -->
                    <TextBlock Text="Пароль" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="RegPasswordBox" Style="{StaticResource DarkPasswordBoxStyle}" Margin="0,0,0,4"
                                 PasswordChanged="RegPasswordBox_PasswordChanged"/>
                    <TextBlock Margin="4,3,0,16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Text" Value="{Binding PasswordHint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PasswordHint}" Value="✓">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Style="{StaticResource AccentButtonStyle}" Content="Зарегистрироваться"
                            HorizontalAlignment="Stretch" Command="{Binding RegisterCommand}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <TextBlock Text="Уже есть аккаунт? " Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding ToggleRegisterCommand}">
                            <TextBlock Text="Войти" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Demo hint -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16,13" Margin="0,28,0,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🔑 Демо-доступ" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="Email: user@cinema.ru" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="Пароль: password123" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
