<UserControl x:Class="CinemaApp.Views.MyTicketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Мои билеты" Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="22" FontWeight="Bold" Margin="24,20,24,16"/>

        <!-- Tabs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,0,24,16">
            <Button Content="Предстоящие" Command="{Binding SwitchToUpcomingCommand}"
                    Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowUpcoming}" Value="False">
                                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="История" Command="{Binding SwitchToHistoryCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowUpcoming}" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Ticket lists -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,24">
                <!-- Upcoming -->
                <ItemsControl ItemsSource="{Binding UpcomingTickets}"
                              Visibility="{Binding ShowUpcoming, Converter={StaticResource BoolVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Margin="0,0,0,12" Padding="16">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="8" Opacity="0.3" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MovieTitle}" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0">
                                            <Run Text="{Binding SessionTime, StringFormat=dd MMMM yyyy · HH:mm}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                                            <Run Text="{Binding HallName}"/>
                                            <Run Text=" · Место "/>
                                            <Run Text="{Binding SeatDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="Bold" Margin="0,6,0,0">
                                            <Run Text="{Binding Price, StringFormat=N0}"/><Run Text=" ₽"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Style="{StaticResource AccentButtonStyle}" Content="Показать QR" Padding="12,8"
                                                    Command="{Binding DataContext.ShowTicketQrCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource GhostButtonStyle}" Content="Отменить" Padding="12,8" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.CancelTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- QR placeholder -->
                                    <Border Grid.Column="1" Width="80" Height="80" Background="{StaticResource SurfaceBrush}"
                                            CornerRadius="8" Margin="12,0,0,0" VerticalAlignment="Top">
                                        <TextBlock Text="QR" Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="20" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Past (History) -->
                <ItemsControl ItemsSource="{Binding PastTickets}">
                    <ItemsControl.Visibility>
                        <Binding Path="ShowUpcoming" Converter="{StaticResource BoolVis}" ConverterParameter="invert"/>
                    </ItemsControl.Visibility>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="12" Opacity="0.6"
                                    Margin="0,0,0,12" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MovieTitle}" Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0">
                                            <Run Text="{Binding SessionTime, StringFormat=dd MMMM yyyy · HH:mm}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                            <Run Text="Место "/>
                                            <Run Text="{Binding SeatDisplay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                                            CornerRadius="4" Padding="8,4" VerticalAlignment="Top">
                                        <TextBlock Text="Просмотрено" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty states -->
                <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0"
                            Visibility="{Binding IsUpcomingEmpty, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="У вас нет предстоящих билетов" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15" HorizontalAlignment="Center"/>
                    <TextBlock Text="Найдите фильм и забронируйте место" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
