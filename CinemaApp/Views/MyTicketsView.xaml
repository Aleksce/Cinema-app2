<UserControl x:Class="CinemaApp.Views.MyTicketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎟" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Мои билеты" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="24,0,24,0">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SwitchToUpcomingCommand}" Padding="0,14" Margin="0,0,24,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel>
                                <TextBlock Text="Предстоящие" FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <Binding Path="DataContext.ShowUpcoming" RelativeSource="{RelativeSource AncestorType=UserControl}">
                                            <Binding.Converter>
                                                <conv:BoolToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Foreground>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Height="2" CornerRadius="1" Margin="0,4,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </StackPanel>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding SwitchToHistoryCommand}" Padding="0,14" Margin="0,0,24,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel>
                                <TextBlock Text="История" FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Height="2" CornerRadius="1" Margin="0,4,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </StackPanel>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Ticket lists -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">

                <!-- Upcoming -->
                <ItemsControl ItemsSource="{Binding UpcomingTickets}"
                              Visibility="{Binding ShowUpcoming, Converter={StaticResource BoolVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="16"
                                    Margin="0,0,0,14" ClipToBounds="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.35" ShadowDepth="3"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top: colored bar -->
                                    <Border Grid.Row="0" Height="4">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#E50914" Offset="0"/>
                                                <GradientStop Color="#FF6B35" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Content -->
                                    <Grid Grid.Row="1" Margin="18,14,18,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding MovieTitle}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="17" FontWeight="Bold" TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Margin="5,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                                                    <Run Text="{Binding SessionTime, Mode=OneWay, StringFormat='dd MMMM yyyy · HH:mm'}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="🏛" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Margin="5,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                                                    <Run Text="{Binding HallName, Mode=OneWay}"/>
                                                    <Run Text=" · Место "/>
                                                    <Run Text="{Binding SeatDisplay, Mode=OneWay}"
                                                         Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Separator dashed line -->
                                            <Rectangle Margin="0,12,0,12" Height="1" Fill="{StaticResource BorderBrush}"
                                                       StrokeDashArray="4 4" Stroke="{StaticResource BorderBrush}" StrokeThickness="1"
                                                       Opacity="0.4"/>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                                           FontSize="18" FontWeight="Bold">
                                                    <Run Text="{Binding Price, Mode=OneWay, StringFormat=N0}"/><Run Text=" ₽"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Style="{StaticResource AccentButtonStyle}" Content="Показать QR"
                                                        Padding="14,8" FontSize="12"
                                                        Command="{Binding DataContext.ShowTicketQrCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource GhostButtonStyle}" Content="Отменить"
                                                        Padding="14,8" FontSize="12" Margin="8,0,0,0"
                                                        Command="{Binding DataContext.CancelTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- QR block -->
                                        <Border Grid.Column="1" Width="76" Height="76"
                                                Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="10" VerticalAlignment="Top"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="▦" FontSize="30"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="QR" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Past (History) -->
                <ItemsControl ItemsSource="{Binding PastTickets}">
                    <ItemsControl.Visibility>
                        <Binding Path="ShowUpcoming" Converter="{StaticResource BoolVis}" ConverterParameter="invert"/>
                    </ItemsControl.Visibility>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="12" Opacity="0.65"
                                    Margin="0,0,0,10" Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MovieTitle}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" Margin="0,5,0,0">
                                            <Run Text="{Binding SessionTime, Mode=OneWay, StringFormat='dd MMMM yyyy · HH:mm'}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0">
                                            <Run Text="Место "/>
                                            <Run Text="{Binding SeatDisplay, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Price, Mode=OneWay, StringFormat=N0}"/>
                                            <Run Text=" ₽"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1A3A3A4A"
                                            CornerRadius="6" Padding="10,5" VerticalAlignment="Center"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <TextBlock Text="Просмотрено"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty: upcoming -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                            Visibility="{Binding IsUpcomingEmpty, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Нет предстоящих билетов" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    <TextBlock Text="Найдите фильм и забронируйте место" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
