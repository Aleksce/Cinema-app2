<UserControl x:Class="CinemaApp.Views.MyTicketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎟" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Мои билеты"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,0,24,0">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SwitchToUpcomingCommand}" Padding="0,14"
                        Margin="0,0,24,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel>
                                <TextBlock Text="Предстоящие" FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Height="2" CornerRadius="1" Margin="0,4,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </StackPanel>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Command="{Binding SwitchToHistoryCommand}" Padding="0,14"
                        Margin="0,0,24,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <StackPanel>
                                <TextBlock Text="История" FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Height="2" CornerRadius="1" Margin="0,4,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowUpcoming,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="False">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </StackPanel>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">

                <!-- ══ UPCOMING TICKETS ════════════════════════════════ -->
                <ItemsControl ItemsSource="{Binding UpcomingTickets}"
                              Visibility="{Binding ShowUpcoming, Converter={StaticResource BoolVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="16"
                                    Margin="0,0,0,16" ClipToBounds="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="14"
                                                      Opacity="0.4" ShadowDepth="4"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Accent stripe -->
                                    <Border Grid.Row="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#E50914" Offset="0"/>
                                                <GradientStop Color="#FF6B35" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="18,14,18,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="96"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding MovieTitle}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="16" FontWeight="Bold"
                                                       TextWrapping="Wrap" MaxWidth="280"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Margin="6,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="13">
                                                    <Run Text="{Binding SessionTime, Mode=OneWay,
                                                        StringFormat='dd MMMM yyyy'}"/>
                                                    <Run Text=" · " Foreground="#555570"/>
                                                    <Run Text="{Binding SessionTime, Mode=OneWay,
                                                        StringFormat='HH:mm'}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <TextBlock Text="🏛" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Margin="6,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="13">
                                                    <Run Text="{Binding HallName, Mode=OneWay}"/>
                                                    <Run Text="  ·  " Foreground="#555570"/>
                                                    <Run Text="Место "/>
                                                    <Run Text="{Binding SeatDisplay, Mode=OneWay}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         FontWeight="Bold"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Separator Background="{StaticResource BorderBrush}"
                                                       Opacity="0.3" Margin="0,12,0,12"/>

                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                                       FontSize="20" FontWeight="Bold" Margin="0,0,0,12">
                                                <Run Text="{Binding Price, Mode=OneWay, StringFormat=N0}"/>
                                                <Run Text=" ₽"/>
                                            </TextBlock>

                                            <WrapPanel>
                                                <!-- Download PDF button -->
                                                <Button Padding="0" BorderThickness="0"
                                                        Background="Transparent" Cursor="Hand"
                                                        Margin="0,0,8,6"
                                                        Command="{Binding DataContext.DownloadTicketPdfCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Border Background="{StaticResource AccentBrush}"
                                                            CornerRadius="8" Padding="14,8">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="📄 " Foreground="White"
                                                                       FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Скачать PDF" Foreground="White"
                                                                       FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Button>

                                                <!-- Cancel button -->
                                                <Button Padding="0" BorderThickness="0"
                                                        Background="Transparent" Cursor="Hand"
                                                        Margin="0,0,0,6"
                                                        Command="{Binding DataContext.CancelTicketCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Border Background="Transparent" CornerRadius="8" Padding="14,8"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1">
                                                        <TextBlock Text="Отменить"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="12"/>
                                                    </Border>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- QR preview box -->
                                        <Border Grid.Column="1" Width="82" Height="82"
                                                Background="#0D1120" CornerRadius="10"
                                                VerticalAlignment="Top" Margin="12,0,0,0"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="▦" FontSize="30"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="QR-КОД" FontSize="8"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding QrCode}"
                                                           Foreground="#336080A0"
                                                           FontSize="6" HorizontalAlignment="Center"
                                                           TextWrapping="Wrap" TextAlignment="Center"
                                                           Margin="4,2,4,0" MaxWidth="74"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Upcoming empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                            Visibility="{Binding IsUpcomingEmpty, Converter={StaticResource BoolVis}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ShowUpcoming}" Value="True"/>
                                        <Condition Binding="{Binding IsUpcomingEmpty}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="🎬" FontSize="52" HorizontalAlignment="Center"/>
                    <TextBlock Text="Нет предстоящих билетов"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="17" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="Найдите фильм и забронируйте место"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- ══ HISTORY TAB ════════════════════════════════════ -->
                <ItemsControl ItemsSource="{Binding PastTickets}">
                    <ItemsControl.Visibility>
                        <Binding Path="ShowUpcoming" Converter="{StaticResource BoolVis}"
                                 ConverterParameter="invert"/>
                    </ItemsControl.Visibility>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Opacity="0.72" Margin="0,0,0,10" Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MovieTitle}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" Margin="0,5,0,0">
                                            <Run Text="{Binding SessionTime, Mode=OneWay,
                                                StringFormat='dd MMMM yyyy · HH:mm'}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" Margin="0,2,0,0">
                                            <Run Text="Место "/>
                                            <Run Text="{Binding SeatDisplay, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Price, Mode=OneWay, StringFormat=N0}"/>
                                            <Run Text=" ₽"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <!-- PDF download for past tickets -->
                                        <Button Padding="0" BorderThickness="0"
                                                Background="Transparent" Cursor="Hand" Margin="0,0,0,6"
                                                Command="{Binding DataContext.DownloadTicketPdfCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Border Background="#1A2030" CornerRadius="6" Padding="10,5"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                <TextBlock Text="📄 PDF"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                            </Border>
                                        </Button>
                                        <!-- Status badge -->
                                        <Border Background="#1A3A3A4A" CornerRadius="6" Padding="10,5"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Просмотрено"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="Cancelled">
                                                                <Setter Property="Text"       Value="Отменён"/>
                                                                <Setter Property="Foreground" Value="#FF6060"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- History empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ShowUpcoming}" Value="False"/>
                                        <Condition Binding="{Binding PastTickets.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📜" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="История просмотров пуста"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    <TextBlock Text="Ваши просмотренные фильмы появятся здесь"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
