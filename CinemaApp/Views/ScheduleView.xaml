<UserControl x:Class="CinemaApp.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- Hover animation for session rows -->
        <Style x:Key="ScheduleRowStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1.015" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1.015" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1" Duration="0:0:0.08"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1" Duration="0:0:0.08"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📅" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Расписание сеансов" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Ближайшие 7 дней · только предстоящие сеансы"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Refresh button -->
                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                        Content="⟳ Обновить" Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,24">

                <!-- Loading indicator -->
                <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Center" Margin="0,40,0,0">
                    <TextBlock Text="Загрузка расписания..." Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14"/>
                </Border>

                <!-- Session days -->
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,24">
                                <!-- Day header -->
                                <Border Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="4" CornerRadius="2"
                                                Background="{StaticResource AccentBrush}"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding DayLabel}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Sessions -->
                                <ItemsControl ItemsSource="{Binding Sessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,8" Style="{StaticResource ScheduleRowStyle}"
                                                    Command="{Binding DataContext.SelectSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Border Background="{StaticResource CardBrush}" CornerRadius="14"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000" BlurRadius="8"
                                                                          Opacity="0.25" ShadowDepth="2"/>
                                                    </Border.Effect>
                                                    <Grid Margin="16,14">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Time + format -->
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding StartTime, StringFormat=HH:mm}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="22" FontWeight="Black"
                                                                       HorizontalAlignment="Center"/>
                                                            <Border Background="{StaticResource AccentBrush}"
                                                                    CornerRadius="4" Padding="6,2"
                                                                    Margin="0,4,0,0" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding Format}"
                                                                           Foreground="White"
                                                                           FontSize="10" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- Divider -->
                                                        <Rectangle Grid.Column="0" Width="1"
                                                                   Fill="{StaticResource BorderBrush}"
                                                                   HorizontalAlignment="Right" Margin="0,4"/>

                                                        <!-- Movie info + hall address -->
                                                        <StackPanel Grid.Column="1" Margin="16,0,0,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Movie.Title}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="15" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Text="📍 " FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                <TextBlock Text="{Binding Hall.Name}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="11"/>
                                                            </StackPanel>
                                                            <TextBlock Foreground="#77AAAACC"
                                                                       FontSize="10" Margin="0,2,0,0"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding Hall.Address}"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                <TextBlock Text="{Binding Movie.Genre}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="200"/>
                                                                <TextBlock Text=" · " Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="11"/>
                                                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="11">
                                                                    <Run Text="{Binding Movie.DurationMinutes}"/><Run Text=" мин"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Price + Buy -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                                    Margin="12,0,0,0">
                                                            <TextBlock Foreground="{StaticResource GoldBrush}"
                                                                       FontSize="16" FontWeight="Bold"
                                                                       HorizontalAlignment="Right">
                                                                <Run Text="{Binding BasePrice, StringFormat=N0}"/><Run Text=" ₽"/>
                                                            </TextBlock>
                                                            <Border Background="{StaticResource AccentBrush}"
                                                                    CornerRadius="8" Padding="16,8"
                                                                    Margin="0,8,0,0" Cursor="Hand">
                                                                <TextBlock Text="Купить" Foreground="White"
                                                                           FontSize="13" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                    <TextBlock Text="{Binding Days.Count, FallbackValue=0}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Days.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Days.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="Расписание появится после синхронизации"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Days.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
