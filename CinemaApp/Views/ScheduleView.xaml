<UserControl x:Class="CinemaApp.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📅" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Расписание" Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Сеансы на ближайшие 7 дней"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Schedule list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,24">
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,20">
                                <!-- Day header -->
                                <Border Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="3" CornerRadius="2" Background="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding DayLabel}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Sessions for this day -->
                                <ItemsControl ItemsSource="{Binding Sessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,8" Padding="0" BorderThickness="0"
                                                    Background="Transparent" Cursor="Hand"
                                                    Command="{Binding DataContext.SelectSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{StaticResource CardBrush}" CornerRadius="12"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="#000000" BlurRadius="6" Opacity="0.2" ShadowDepth="2"/>
                                                            </Border.Effect>
                                                            <Grid Margin="14,12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="70"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Time -->
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding StartTime, StringFormat=HH:mm}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Format}"
                                                                               Foreground="{StaticResource AccentBrush}"
                                                                               FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                                </StackPanel>

                                                                <!-- Vertical divider -->
                                                                <Rectangle Grid.Column="0" Width="1"
                                                                           Fill="{StaticResource BorderBrush}"
                                                                           HorizontalAlignment="Right" Margin="0,4"/>

                                                                <!-- Movie info -->
                                                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Movie.Title}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="14" FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontSize="12" Margin="0,3,0,0">
                                                                        <Run Text="{Binding Hall.Name}"/>
                                                                    </TextBlock>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                        <TextBlock Text="{Binding Movie.Genre}"
                                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                                   FontSize="11"
                                                                                   TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                                                        <TextBlock Text=" · " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                                            <Run Text="{Binding Movie.DurationMinutes}"/><Run Text=" мин"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <!-- Price + button -->
                                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                                                                    <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                               FontSize="15" FontWeight="Bold" HorizontalAlignment="Right">
                                                                        <Run Text="{Binding BasePrice, StringFormat=N0}"/><Run Text=" ₽"/>
                                                                    </TextBlock>
                                                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="6"
                                                                            Padding="12,6" Margin="0,6,0,0" Cursor="Hand">
                                                                        <TextBlock Text="Купить" Foreground="White"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                    <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Расписание загружается..." Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="15" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
