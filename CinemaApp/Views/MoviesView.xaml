<UserControl x:Class="CinemaApp.Views.MoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Border Grid.Row="0" Margin="20,16,20,8">
            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14">
                <TextBox.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍  Поиск фильмов..."
                                                           Foreground="#9090A0" FontSize="14"
                                                           Margin="12,10"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </Border>

        <!-- Genre filters -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Margin="20,0,20,12">
            <ItemsControl ItemsSource="{Binding Genres}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding}" Margin="0,0,8,0"
                                Command="{Binding DataContext.SelectGenreCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Padding" Value="14,7"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Movie grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,0,20,20">
                <TextBlock Text="Сейчас в кино" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

                <ItemsControl ItemsSource="{Binding FilteredMovies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,16,16" Padding="0" BorderThickness="0"
                                    Background="Transparent" Cursor="Hand"
                                    Command="{Binding DataContext.SelectMovieCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <!-- NOTE: ScaleTransform must be named so ControlTemplate
                                             EventTrigger Storyboards can target it by name directly
                                             (Storyboard.TargetName + TargetProperty="ScaleX").
                                             Using the full attached-property path
                                             "(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             also works but only when the exact transform type is
                                             known at parse time — targeting by name is more robust. -->
                                        <Border x:Name="CardRoot"
                                                Background="{StaticResource CardBrush}"
                                                CornerRadius="12" Width="185"
                                                ClipToBounds="False"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Border.Effect>
                                                <DropShadowEffect x:Name="CardShadow"
                                                                  Color="#000000" BlurRadius="12"
                                                                  Opacity="0.4" ShadowDepth="4"/>
                                            </Border.Effect>

                                            <Border CornerRadius="12" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="270"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Poster -->
                                                    <Image Grid.Row="0" Stretch="UniformToFill"
                                                           Source="{Binding PosterUrl}"
                                                           ClipToBounds="True"/>

                                                    <!-- Hover overlay tint -->
                                                    <Border x:Name="HoverOverlay" Grid.Row="0"
                                                            Background="#00E50914" CornerRadius="0"/>

                                                    <!-- Age badge -->
                                                    <Border Grid.Row="0" HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,8,8,0"
                                                            Background="#CC000000"
                                                            CornerRadius="4" Padding="5,2">
                                                        <TextBlock Text="{Binding AgeRating}"
                                                                   Foreground="White"
                                                                   FontSize="11" FontWeight="Bold"/>
                                                    </Border>

                                                    <!-- Rating badge bottom-left -->
                                                    <Border Grid.Row="0" HorizontalAlignment="Left"
                                                            VerticalAlignment="Bottom"
                                                            Margin="8,0,0,8"
                                                            Background="#CC000000"
                                                            CornerRadius="4" Padding="6,3">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="★" FontSize="11"
                                                                       Foreground="{StaticResource GoldBrush}"/>
                                                            <TextBlock Text="{Binding ImdbRating, StringFormat=F1}"
                                                                       Foreground="{StaticResource GoldBrush}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Margin="3,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Info block -->
                                                    <StackPanel Grid.Row="1" Margin="10,8,10,10">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   TextWrapping="Wrap" MaxHeight="38"/>
                                                        <TextBlock Text="{Binding Genre}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11" Margin="0,3,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Border>

                                        <!-- Hover + click animations -->
                                        <!-- Target the NAMED ScaleTransform directly — avoids the
                                             XamlParseException "cannot resolve RenderTransform.ScaleX" -->
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="1.05" Duration="0:0:0.15"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleY"
                                                            To="1.05" Duration="0:0:0.15"/>
                                                        <ColorAnimation
                                                            Storyboard.TargetName="HoverOverlay"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#22E50914" Duration="0:0:0.15"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardShadow"
                                                            Storyboard.TargetProperty="BlurRadius"
                                                            To="24" Duration="0:0:0.15"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardShadow"
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="0.7" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="1" Duration="0:0:0.12"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleY"
                                                            To="1" Duration="0:0:0.12"/>
                                                        <ColorAnimation
                                                            Storyboard.TargetName="HoverOverlay"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            To="#00E50914" Duration="0:0:0.12"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardShadow"
                                                            Storyboard.TargetProperty="BlurRadius"
                                                            To="12" Duration="0:0:0.12"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardShadow"
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="0.4" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="0.97" Duration="0:0:0.06"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleY"
                                                            To="0.97" Duration="0:0:0.06"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleX"
                                                            To="1.05" Duration="0:0:0.08"/>
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="CardScale"
                                                            Storyboard.TargetProperty="ScaleY"
                                                            To="1.05" Duration="0:0:0.08"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}"
                            HorizontalAlignment="Center" Margin="0,60,0,0">
                    <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ничего не найдено"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="16" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Sync status bar -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Background="#CC1A1A2E" Padding="16,8"
                Visibility="{Binding SyncStatus, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⟳ " Foreground="{StaticResource AccentBrush}"
                           FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SyncStatus}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="2" Background="#CC101018" VerticalAlignment="Center"
                HorizontalAlignment="Center" CornerRadius="12" Padding="24,14"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <TextBlock Text="Загрузка..." Foreground="White" FontSize="14"/>
        </Border>
    </Grid>
</UserControl>
