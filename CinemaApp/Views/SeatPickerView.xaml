<UserControl x:Class="CinemaApp.Views.SeatPickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CinemaApp.ViewModels"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="SeatStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Width"        Value="28"/>
            <Setter Property="Height"       Value="24"/>
            <Setter Property="Background"   Value="#2A3A5C"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- VIP seat -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Type}"       Value="VIP"/>
                        <Condition Binding="{Binding Status}"     Value="Available"/>
                        <Condition Binding="{Binding IsSelected}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1A3820"/>
                </MultiDataTrigger>
                <!-- Sofa seat (was incorrectly "Comfort") -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Type}"       Value="Sofa"/>
                        <Condition Binding="{Binding Status}"     Value="Available"/>
                        <Condition Binding="{Binding IsSelected}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#3A2810"/>
                </MultiDataTrigger>
                <!-- Occupied — cursor arrow, muted colour -->
                <DataTrigger Binding="{Binding Status}" Value="Occupied">
                    <Setter Property="Background" Value="#252530"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </DataTrigger>
                <!-- Selected — accent colour + bounce animation -->
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#E50914"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                    From="0.85" To="1.1" Duration="0:0:0.08" AutoReverse="True"/>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                    From="0.85" To="1.1" Duration="0:0:0.08" AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PromoInputStyle" TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}">
            <Setter Property="Padding"   Value="10,8"/>
            <Setter Property="FontSize"  Value="13"/>
            <Setter Property="MaxLength" Value="12"/>
            <Setter Property="CharacterCasing" Value="Upper"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Button Style="{StaticResource GhostButtonStyle}" Content="← Назад"
                        HorizontalAlignment="Left" Command="{Binding GoBackCommand}"/>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Session.Movie.Title}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" HorizontalAlignment="Center">
                        <Run Text="{Binding Session.StartTime, StringFormat='dd MMMM · HH:mm'}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding Session.Hall.Name}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Session.Hall.Address}"
                               Foreground="#556680" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Screen bar -->
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <Border Margin="60,0,60,0" Height="5" CornerRadius="3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E50914" Offset="0"/>
                        <GradientStop Color="#FF6B35" Offset="0.5"/>
                        <GradientStop Color="#E50914" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <TextBlock Text="—  Э К Р А Н  —"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="10" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,5,0,8"/>
        </StackPanel>

        <!-- Main area: seat grid OR loading OR all-occupied banner -->
        <Grid Grid.Row="2">

            <!-- Loading overlay -->
            <Border Background="#CC101018" VerticalAlignment="Center"
                    HorizontalAlignment="Center" CornerRadius="12" Padding="24,14"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
                <TextBlock Text="Загрузка мест..." Foreground="White" FontSize="14"/>
            </Border>

            <!-- All-seats-occupied banner -->
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="24,0" CornerRadius="14" Padding="28,20"
                    Visibility="{Binding AllSeatsOccupied, Converter={StaticResource BoolVis}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A0A0A" Offset="0"/>
                        <GradientStop Color="#2A0A14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="😔" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Все места проданы" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="18" FontWeight="Bold" Margin="0,14,0,6"/>
                    <TextBlock Text="На этот сеанс билеты закончились. Выберите другое время."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300"
                               Margin="0,0,0,20"/>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Content="← Другой сеанс" HorizontalAlignment="Center"
                            Command="{Binding GoBackCommand}"/>
                </StackPanel>
            </Border>

            <!-- Seat grid (normal state) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Visibility="{Binding AllSeatsOccupied,
                              Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center" Margin="20,4,20,12">

                    <!-- Legend -->
                    <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                            Padding="14,8" Margin="0,0,0,14" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="18" Height="14" RadiusX="3" RadiusY="3" Fill="#2A3A5C"/>
                            <TextBlock Text="Стандарт" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="5,0,14,0" VerticalAlignment="Center"/>
                            <Rectangle Width="18" Height="14" RadiusX="3" RadiusY="3" Fill="#1A3820"/>
                            <TextBlock Text="VIP" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="5,0,14,0" VerticalAlignment="Center"/>
                            <Rectangle Width="18" Height="14" RadiusX="3" RadiusY="3" Fill="#3A2810"/>
                            <TextBlock Text="Комфорт" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="5,0,14,0" VerticalAlignment="Center"/>
                            <Rectangle Width="18" Height="14" RadiusX="3" RadiusY="3" Fill="#E50914"/>
                            <TextBlock Text="Выбрано" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="5,0,14,0" VerticalAlignment="Center"/>
                            <Rectangle Width="18" Height="14" RadiusX="3" RadiusY="3" Fill="#252530"/>
                            <TextBlock Text="Занято" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Seat rows -->
                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SeatRowViewModel}">
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="26"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding RowLabel}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Seats}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SeatViewModel}">
                                                <Button Margin="2,0" Padding="0"
                                                        Width="28" Height="24"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.ToggleSeatCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Style="{StaticResource SeatStyle}"/>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Grid.Column="2" Text="{Binding RowLabel}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom panel: promo code + summary + pay -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,14">
            <StackPanel>

                <!-- Promo code row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding PromoCodeInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PromoInputStyle}"
                             VerticalAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource PromoInputStyle}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="  Введите промокод..."
                                                                   Foreground="#556680" FontSize="13"
                                                                   Margin="10,8"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" Margin="8,0,0,0"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="Применить" Padding="14,8"
                            Command="{Binding ApplyPromoCodeCommand}"
                            VerticalAlignment="Center"/>
                    <!-- Clear discount button -->
                    <Button Grid.Column="2" Margin="6,0,0,0"
                            Padding="8,8" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            Visibility="{Binding HasDiscount, Converter={StaticResource BoolVis}}"
                            ToolTip="Убрать скидку">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="✕" Foreground="#9090A0" FontSize="12"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Command>
                            <Binding Path="ApplyPromoCodeCommand"/>
                        </Button.Command>
                    </Button>
                </Grid>

                <!-- Promo status message -->
                <TextBlock Margin="0,0,0,8" FontSize="12"
                           Visibility="{Binding PromoStatus, Converter={StaticResource BoolVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PromoStatus[0]}" Value="❌">
                                    <Setter Property="Foreground" Value="#FF6060"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding PromoStatus}"/>
                </TextBlock>

                <!-- Summary + price + pay -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectionSummary}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <!-- Original price (strikethrough when discount active) -->
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" TextDecorations="Strikethrough"
                                   Visibility="{Binding HasDiscount, Converter={StaticResource BoolVis}}">
                            <Run Text="{Binding TotalPrice, StringFormat=N0}"/><Run Text=" ₽"/>
                        </TextBlock>
                        <!-- Final price -->
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   FontSize="20" FontWeight="Bold"
                                   Visibility="{Binding HasSelection, Converter={StaticResource BoolVis}}">
                            <Run Text="{Binding FinalPrice, StringFormat=N0}"/><Run Text=" ₽"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}"
                            Content="Оплатить" Width="140"
                            Command="{Binding PurchaseCommand}"
                            IsEnabled="{Binding HasSelection}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
