<UserControl x:Class="CinemaApp.Views.PromotionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CinemaApp.Converters"
             Background="{StaticResource PrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎁" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Акции и скидки" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Специальные предложения для наших гостей"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <!-- Loyalty card teaser -->
                <Border HorizontalAlignment="Right" Background="#1A1A3A" CornerRadius="10"
                        Padding="16,10" BorderBrush="#33E50914" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⭐" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Синема Клуб" Foreground="White" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="Накапливайте баллы с каждой покупки"
                                       Foreground="#99C0C0D0" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Copy confirmation toast -->
        <Border Grid.Row="1" Background="#CC2D7A2D" Padding="16,10"
                Visibility="{Binding StatusMessage, Converter={StaticResource BoolVis}, FallbackValue=Collapsed}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="✓  " Foreground="White" FontSize="13" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="13"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,24">
                <ItemsControl ItemsSource="{Binding Promotions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="16" Margin="0,0,0,16" ClipToBounds="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" BlurRadius="14" Opacity="0.4" ShadowDepth="3"/>
                                </Border.Effect>
                                <Grid>
                                    <!-- Gradient background -->
                                    <Border CornerRadius="16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{Binding GradientFrom}" Offset="0"/>
                                                <GradientStop Color="{Binding GradientTo}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border CornerRadius="16" BorderBrush="#22FFFFFF" BorderThickness="1"/>

                                    <Grid Margin="20,18">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Icon + badge row -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Icon}" FontSize="26"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="8"
                                                    Padding="10,4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Badge}" Foreground="White"
                                                           FontSize="12" FontWeight="Black"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Title + subtitle -->
                                        <TextBlock Grid.Row="1" Text="{Binding Title}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                        <!-- Description + how to use -->
                                        <StackPanel Grid.Row="3" Margin="0,0,0,14">
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#99FFFFFF" FontSize="11"
                                                       TextWrapping="Wrap" LineHeight="16">
                                                <Run Text="Как использовать: "/><Run Text="{Binding HowToUse}"
                                                     FontStyle="Italic"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Footer: validity + promo code -->
                                        <Grid Grid.Row="4">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🕒 " FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding ValidUntil}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>

                                            <!-- Promo code copy button -->
                                            <Button HorizontalAlignment="Right" Cursor="Hand"
                                                    Padding="0" BorderThickness="0" Background="Transparent"
                                                    Visibility="{Binding HasPromoCode, Converter={StaticResource BoolVis}}"
                                                    Command="{Binding DataContext.CopyPromoCodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding PromoCode}">
                                                <Border CornerRadius="8" BorderBrush="#44FFFFFF"
                                                        BorderThickness="1" Padding="12,6">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#22FFFFFF"/>
                                                    </Border.Background>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📋 " Foreground="White" FontSize="11"/>
                                                        <TextBlock Foreground="White" FontSize="11" FontWeight="Bold">
                                                            <Run Text="{Binding PromoCode}" FontFamily="Courier New"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
